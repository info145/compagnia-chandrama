# ────────────────────────────────────────────────
# Copia questo file in .env e riempi i valori.
# NON caricare .env su GitHub (già in .gitignore)
# Aggiungi queste variabili anche su Vercel:
#   Dashboard Vercel → Settings → Environment Variables
# ────────────────────────────────────────────────

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# URL pubblico del sito (senza slash finale)
SITE_URL=https://compagnia-chandrama.vercel.app

# Vimeo OTT — URL embed dello spettacolo registrato
# Prendilo da: Vimeo OTT → Il tuo video → Share/Embed
VIMEO_VOD_URL=https://vimeo.com/showcase/INSERISCI_QUI

# Vimeo OTT — URL embed dell'evento live (se attivo)
VIMEO_LIVE_URL=https://vimeo.com/event/INSERISCI_QUI/embed
